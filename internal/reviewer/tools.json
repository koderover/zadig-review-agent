[
  {
    "name": "file_read",
    "description": "Read a line range from a repository file in the post-change snapshot.",
    "parameters": {
      "type": "object",
      "properties": {
        "file_path": {"type": "string"},
        "start_line": {"type": "integer", "minimum": 1},
        "end_line": {"type": "integer", "minimum": 1}
      },
      "required": ["file_path"]
    }
  },
  {
    "name": "code_search",
    "description": "Search tracked repository files. file_patterns are Git pathspecs; use_perl_regexp enables PCRE.",
    "parameters": {
      "type": "object",
      "properties": {
        "search_text": {"type": "string"},
        "file_patterns": {"type": "array", "items": {"type": "string"}},
        "case_sensitive": {"type": "boolean"},
        "use_perl_regexp": {"type": "boolean"}
      },
      "required": ["search_text"]
    }
  },
  {
    "name": "file_find",
    "description": "Find repository files by matching a keyword against file basenames. This is not a glob search.",
    "parameters": {
      "type": "object",
      "properties": {
        "query_name": {"type": "string"},
        "case_sensitive": {"type": "boolean"}
      },
      "required": ["query_name"]
    }
  },
  {
    "name": "code_comment",
    "description": "Record one concrete finding for changed code in the current file.",
    "parameters": {
      "type": "object",
      "properties": {
        "finding": {
          "type": "object",
          "properties": {
            "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
            "category": {"type": "string", "enum": ["correctness", "security", "concurrency", "performance", "compatibility", "tests"]},
            "rule_id": {"type": "string"},
            "file": {"type": "string"},
            "start_line": {"type": "integer"},
            "end_line": {"type": "integer"},
            "existing_code": {"type": "string"},
            "title": {"type": "string"},
            "problem": {"type": "string"},
            "evidence": {"type": "string"},
            "suggestion": {"type": "string"},
            "confidence": {"type": "number", "minimum": 0, "maximum": 1}
          },
          "required": ["severity", "category", "title", "problem", "evidence", "suggestion", "confidence"]
        }
      },
      "required": ["finding"]
    }
  },
  {
    "name": "task_done",
    "description": "Finish reviewing the current file after all necessary context checks and comments are complete.",
    "parameters": {"type": "object", "properties": {}}
  }
]
